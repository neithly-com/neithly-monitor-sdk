{
  "name": "@neithly-com/monitor-browser",
  "version": "0.0.0",
  "description": "Browser SDK for neithly-monitor — fetch-based OTLP exporter, Sentry-shaped public API, window.onerror + fetch / XHR / console instrumentation.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@neithly-com/monitor-core": "workspace:*"
  }
}
