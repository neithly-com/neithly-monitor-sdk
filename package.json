{
  "name": "neithly-monitor-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Official JS/TS SDK family for neithly-monitor — Sentry-shaped API over OTLP/HTTP. Node + Browser + React + CLI.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter='./packages/*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm -r --filter='./packages/*' build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^20.16.10",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.2"
  }
}
